# Copy this to .env.local for local development
# Set these as Environment Variables in your Vercel project dashboard

# Your Supabase project URL (Settings → API)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase service role key (Settings → API → service_role)
# ⚠️ Keep this SECRET — it bypasses Row Level Security
# Never commit this to git or expose it client-side
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
