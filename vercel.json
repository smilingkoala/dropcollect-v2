{
  "version": 2,
  "functions": {
    "api/*.js": {
      "memory": 256,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/c.js", "destination": "/public/c.js" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/api/create", "destination": "/api/create.js" },
    { "source": "/api/collect", "destination": "/api/collect.js" },
    { "source": "/api/emails", "destination": "/api/emails.js" },
    { "source": "/api/config", "destination": "/api/config.js" }
  ]
}